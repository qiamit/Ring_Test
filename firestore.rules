rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAppOwner() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'qicoding1@gmail.com';
    }

    function isTenantMember(tenantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/tenant_memberships/$(tenantId + '_' + request.auth.uid));
    }

    function tenantDoc(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId));
    }

    function isApprovedMember(tenantId) {
      return isTenantMember(tenantId)
        && tenantDoc(tenantId).data.status == 'approved';
    }

    match /user_profiles/{userId} {
      allow read, write: if isAppOwner() || isOwner(userId);
    }

    match /settings/{userId} {
      allow read, write: if isAppOwner() || isOwner(userId);
    }

    match /tenants/{tenantId} {
      allow read: if isAppOwner() || isTenantMember(tenantId);
      allow create: if isSignedIn()
        && request.resource.data.owner_user_id == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAppOwner();
    }

    match /tenant_memberships/{membershipId} {
      allow read: if isAppOwner()
        || (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow write: if isAppOwner();
    }

    match /tests/{testId} {
      allow read: if isAppOwner()
        || (isSignedIn() && isApprovedMember(resource.data.tenant_id));
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid
        && isApprovedMember(request.resource.data.tenant_id);
      allow update, delete: if isAppOwner()
        || (isSignedIn()
          && resource.data.user_id == request.auth.uid
          && isApprovedMember(resource.data.tenant_id));
    }

    match /calibrations/{calibrationId} {
      allow read, write: if isAppOwner()
        || (isSignedIn()
          && resource.data.user_id == request.auth.uid
          && isApprovedMember(resource.data.tenant_id));
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid
        && isApprovedMember(request.resource.data.tenant_id);
    }
  }
}
